---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  span?: "normal" | "half" | "wide";
  accent?: "violet" | "cyan" | "gold";
}

const {
  eyebrow,
  title,
  description,
  span = "normal",
  accent = "violet",
} = Astro.props;

const classes = ["content-card", "surface"];

if (span === "half") classes.push("span-half");
if (span === "wide") classes.push("span-wide");

classes.push(`accent-${accent}`);
---

<article class={classes.join(" ")}>
  <div class="card-accent" aria-hidden="true"></div>

  <div class="stack-md card-body">
    {(eyebrow || title || description) && (
      <header class="stack-sm">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <h3>{title}</h3>
        {description && <p class="muted">{description}</p>}
      </header>
    )}

    <slot />
  </div>
</article>

<style>
  .content-card {
    overflow: hidden;
    min-height: 100%;
  }

  .card-body {
    position: relative;
    z-index: 1;
    padding: 1.25rem;
  }

  .card-accent {
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--card-accent), rgba(255, 255, 255, 0));
  }

  .accent-violet {
    --card-accent: rgba(22, 37, 58, 0.92);
  }

  .accent-cyan {
    --card-accent: rgba(110, 123, 141, 0.92);
  }

  .accent-gold {
    --card-accent: rgba(176, 138, 84, 0.92);
  }

  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--accent-strong);
    line-height: 1.15;
  }
</style>
